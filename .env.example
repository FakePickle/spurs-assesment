# Supabase — https://supabase.com/dashboard/project/<project>/settings/api
PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co
SUPABASE_SERVICE_ROLE_KEY=

# Google AI Studio — https://aistudio.google.com/apikey
GOOGLE_AI_API_KEY=

# Optional: override the Gemini model (default: gemini-2.0-flash)
# Supported: gemini-2.0-flash, gemini-2.5-flash
GEMINI_MODEL=

# Optional: Redis for session caching (omit or leave blank to disable cache)
# Format: redis://[:password@]host[:port][/db]
REDIS_URL=
